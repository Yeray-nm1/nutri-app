---
export const prerender = false;
import products from '@lib/products.json';
import Layout from '@layouts/Layout.astro';
import Heading from '@components/HeroBanner.astro';
import Results from '@components/results/Results.astro';
import Search from '../components/search/Search.astro';

const monthMap: Record<string, string[]> = {
  'Primavera (Mar - Jun)': ['Mar', 'Abr', 'May', 'Jun'],
  'Verano (Jun - Sep)': ['Jun', 'Jul', 'Ago', 'Sep'],
  'Otoño (Sep - Dic)': ['Sep', 'Oct', 'Nov', 'Dic'],
  'Invierno (Dic - Mar)': ['Dic', 'Ene', 'Feb', 'Mar'],
};

const allRegionsValues = ['Todas', 'Todas las regiones'];
const allSeasonsValues = ['Todas', 'Todas las temporadas'];

const region = Astro.url.searchParams.get('region') ?? '';
const season = Astro.url.searchParams.get('season') ?? '';

const isAllRegions = allRegionsValues.includes(region);
const isAllSeasons = allSeasonsValues.includes(season);
const seasonMonths = season && !isAllSeasons ? (monthMap[season] ?? []) : [];

const filteredProducts = products.filter((product) => {
  const matchesRegion =
    !region || isAllRegions || product.regions.includes(region);
  const matchesSeason =
    !season ||
    isAllSeasons ||
    seasonMonths.some((m) => product.months.includes(m));
  return matchesRegion && matchesSeason;
});

const pageTitle = 'Home | Productos de Temporada';
---

<Layout pageTitle={pageTitle}>
  <Heading />
  <Search />
  <Results products={filteredProducts} />
</Layout>
