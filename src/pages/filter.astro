---
export const prerender = false;
import products from '@lib/products.json';
import Layout from '@layouts/Layout.astro';
import Heading from '@components/HeroBanner.astro';
import Results from '@components/results/Results.astro';
import Search from '../components/search/Search.astro';

const region = Astro.url.searchParams.get('region') ?? '';
const season = Astro.url.searchParams.get('season') ?? '';
const seasonIndex = season.indexOf('(');
const selectedMonth =
  season && seasonIndex !== -1 ? season.slice(seasonIndex + 1, seasonIndex + 4) : '';

const filteredProducts = products.filter((product) => {
  const matchesRegion = !region || product.regions.includes(region);
  const matchesSeason = !selectedMonth || product.months.includes(selectedMonth);
  return matchesRegion && matchesSeason;
});

const pageTitle = "Home | Productos de Temporada";
---

<Layout pageTitle={pageTitle}>
  <Heading />
  <Search />
  <Results products={filteredProducts} />
</Layout>
